; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Forgotten Caves"
run/main_scene="res://scenes/StartMenu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=4160
window/size/viewport_height=2340

[gui]

; 2026-07-05 (Francois : "augmente toutes les tailles de fonte a l'ecran") :
; theme par defaut applique a TOUS les Control (boutons/labels) qui n'ont pas
; de taille de police explicite deja definie (font_size = 20 au lieu du
; defaut Godot 16). Les overrides explicites (TimeLabel, StatsLabel, etc.)
; sont augmentes separement dans leurs fichiers respectifs.
theme/custom="res://themes/DefaultTheme.tres"
